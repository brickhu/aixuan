# ── aiXuan 生产环境变量 ──
# 复制此文件到服务器 /opt/aixuan/.env 并填入实际值
# 参考: docker-compose.yml 中的 environment 字段

# PostgreSQL（Docker 内网，主机名用服务名 postgres）
# DB_PASSWORD 需要单独设置，在 docker-compose.yml 中通过 ${DB_PASSWORD} 引用
DATABASE_URL=postgresql://postgres:${DB_PASSWORD}@postgres:5432/aixuan

# JWT 签名密钥（必填，使用 openssl rand -hex 32 生成）
JWT_SECRET=change-me-to-a-random-hex-string

# DeepSeek API
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxx
DEEPSEEK_BASE_URL=https://api.deepseek.com/anthropic
DEEPSEEK_MODEL=deepseek-v4-flash

# CORS（前端域名）
CORS_ORIGIN=https://www.aixuan.vip

# ── CPS 选填 ──
CPS_TAOBAO_APP_KEY=
CPS_TAOBAO_APP_SECRET=
CPS_TAOBAO_PID=
CPS_JD_API_KEY=
CPS_JD_APP_SECRET=
CPS_PDD_API_KEY=
CPS_PDD_CLIENT_SECRET=
CPS_PDD_PID=