# Server
PORT=3000

# PostgreSQL（本地开发）
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/aixuan

# JWT Secret（必填，生产环境使用强随机字符串）
JWT_SECRET=dev-secret-change-in-production

# DeepSeek API（必填）
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxx
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# CORS（前端开发地址）
CORS_ORIGIN=http://localhost:5173

# Taobao CPS (Alimama TOP API)
CPS_TAOBAO_APP_KEY=
CPS_TAOBAO_APP_SECRET=
CPS_TAOBAO_PID=

# JD Union
CPS_JD_API_KEY=

# Pinduoduo (Duoduoke)
CPS_PDD_API_KEY=